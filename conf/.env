DOMAIN=__DOMAIN__
APP_PORT=__PORT__
SECRET=__APP_SECRET__
DOCKER_NAME=__APP__
HTTP_BIND=127.0.0.1
HTTP_PORT=__PORT__

# Huly environment vars
HULY_VERSION=latest

# Cockroach
CR_DATABASE=huly
CR_USERNAME=huly
CR_USER_PASSWORD=__CR_PASSWORD__
CR_DB_URL=postgresql://huly:__CR_PASSWORD__@cockroach:26257/huly?sslmode=disable

# Redpanda
REDPANDA_ADMIN_USER=admin
REDPANDA_ADMIN_PWD=__REDPANDA_PASSWORD__

HOST_ADDRESS=__DOMAIN__
SECURE=1

# Data volumes to data_dir
VOLUME_CR_DATA_PATH=__DATA_DIR__/cr_data
VOLUME_CR_CERTS_PATH=__DATA_DIR__/cr_certs
VOLUME_REDPANDA_PATH=__DATA_DIR__/redpanda
VOLUME_FILES_PATH=__DATA_DIR__/files
VOLUME_ELASTIC_PATH=__DATA_DIR__/elastic
VOLUME_MONGO_PATH=__DATA_DIR__/mongodb
